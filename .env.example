# DB
POSTGRES_USER=pixelforge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pixelforge
DATABASE_URL=postgresql+psycopg://pixelforge:changeme@postgres:5432/pixelforge

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change_this_super_secret
JWT_EXPIRES_MIN=10080

# Storage
DATA_DIR=/data
PUBLIC_BASE_URL=http://localhost:8000

# Stripe (optionnel au début)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs – one per paid plan (obtain from Stripe Dashboard)
STRIPE_PRICE_STARTER_ID=price_xxx
STRIPE_PRICE_PRO_ID=price_xxx
STRIPE_PRICE_BUSINESS_ID=price_xxx

# Plans / quotas
FREE_MONTHLY_LIMIT=20
STARTER_MONTHLY_LIMIT=300
PRO_MONTHLY_LIMIT=1000
BUSINESS_MONTHLY_LIMIT=5000

# Rate limiting (SlowAPI syntax: "N/period", e.g. "20/minute", "100/hour")
GENERATE_RATE_LIMIT=20/minute

# AI model
MODEL_ID=stabilityai/sdxl-turbo
DEFAULT_STEPS=4
DEFAULT_GUIDANCE=0.0
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
